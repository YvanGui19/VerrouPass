# Configuration du Client VerrouPass (React + Vite)
#
# Variables d'environnement pour le frontend
# Les variables doivent commencer par VITE_ pour être accessibles dans le code

# URL de l'API backend
# En développement: utilisez le proxy Vite (voir vite.config.js)
# En production: utilisez l'URL complète de votre API
#
# Développement (avec proxy Vite):
# VITE_API_URL=/api
#
# Production (si API sur un domaine différent):
# VITE_API_URL=https://api.verroupass.votredomaine.com/api
#
# Production (API et client sur le même domaine - recommandé):
VITE_API_URL=/api

# Nom de l'application (optionnel)
VITE_APP_NAME=VerrouPass

# Version (optionnel)
VITE_APP_VERSION=1.0.0
