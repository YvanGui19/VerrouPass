# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/password_manager

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# 2FA / TOTP - cle maitre AES-256-GCM pour chiffrer les secrets TOTP en DB
# Generer : openssl rand -hex 32
# /!\ NE JAMAIS REGENERER apres mise en service : tous les secrets TOTP des
# utilisateurs avec 2FA active deviendraient indechiffrables.
TOTP_ENCRYPTION_KEY=change-me-64-hex-chars-32-bytes-aes-256-gcm-master-key

# KDF / Argon2id - cle HMAC pour generer un kdf_salt deterministe pour les
# emails inconnus, cote /api/auth/kdf-info (anti-enumeration).
# Generer : openssl rand -hex 32
# Si non definie : warning au demarrage + fallback sur une cle aleatoire
# generee au boot (effective pour la session courante mais change au restart).
# Aucun impact sur les comptes existants : leur kdf_salt est stocke en DB.
KDF_SALT_HMAC_KEY=change-me-64-hex-chars-32-bytes-hmac-key-for-unknown-email

# CORS
CLIENT_URL=http://localhost:5173

# Admin invitation token (POST /api/admin/invitation)
# Generer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_INVITATION_TOKEN=change-me-32-chars-random-hex-token
