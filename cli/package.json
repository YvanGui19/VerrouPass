{
  "name": "verroupass-cli",
  "version": "2.1.1",
  "description": "CLI pour VerrouPass - Gestionnaire de mots de passe zero-knowledge",
  "main": "src/index.js",
  "type": "module",
  "bin": {
    "v-man": "./src/index.js",
    "v-login": "./src/index.js",
    "v-exit": "./src/index.js",
