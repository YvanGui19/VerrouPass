{
  "name": "verroupass-cli",
  "version": "2.3.0",
  "description": "CLI pour VerrouPass - Gestionnaire de mots de passe zero-knowledge",
  "main": "src/index.js",
  "type": "module",
  "bin": {
    "v-man": "./bin/v-man.js",
    "v-login": "./bin/v-login.js",
    "v-exit": "./bin/v-exit.js",
    "v-ls": "./bin/v-ls.js",
    "v-cat": "./bin/v-cat.js",
    "v-grep": "./bin/v-grep.js",
    "v-find": "./bin/v-find.js",
    "v-touch": "./bin/v-touch.js",
    "v-nano": "./bin/v-nano.js",
    "v-rm": "./bin/v-rm.js",
    "v-gen": "./bin/v-gen.js",
